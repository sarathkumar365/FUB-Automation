# Follow Up Boss API
FUB_API_KEY=replace_with_api_key
FUB_BASE_URL=https://api.followupboss.com/v1
# Get these from FUB system registration:
# https://apps.followupboss.com/system-registration
FUB_X_SYSTEM=replace_with_system_name
FUB_X_SYSTEM_KEY=replace_with_system_key

# Polling / rules
POLL_INTERVAL_MS=30000
SHORT_CALL_THRESHOLD_SECONDS=30
DEV_TEST_USER_ID=30

# Database
DB_URL=jdbc:postgresql://localhost:5432/automation_engine
DB_USER=postgres
DB_PASS=postgres

# Spring
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# Admin authentication (dev-hosting-security-hardening A1)
# JWT_SECRET must be at least 32 chars; generate with: openssl rand -base64 48
# Required outside the 'local' profile; in 'local' a random ephemeral key is used if blank.
JWT_SECRET=
JWT_ISSUER=automation-engine
JWT_EXPIRY=8h
# Seed credentials for the first admin user. Used only on first startup when the
# app_user table is empty. Required in non-local profiles.
ADMIN_AUTH_USERNAME=
ADMIN_AUTH_PASSWORD=
